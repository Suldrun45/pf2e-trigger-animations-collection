          "script": {
            "value": "/**\n * @param {unknown[]} inputs\n * @returns {boolean} to break out current process\n * @returns {{type: EntryType; value: unknown}[]}\n *\n * @example\n * const x = inputs[0];\n * const y = inputs[1];\n * return [{type: \"number\", value: x + y}];\n */\nconst msg = inputs[0];\n\nconst isDamageRoll = msg?.isDamageRoll;\nconst item = msg?.item;\nconst token = msg?.token;\nconst rollOptions = msg?.flags?.pf2e?.context?.options;\nconst outcome = msg?.flags?.pf2e?.context?.outcome;\nconst isReroll = msg?.isReroll;\nconst dmgSlugs = msg?.flags?.pf2e?.dice?.map((d) => d?.slug);\nconst modSlugs = msg?.flags?.pf2e?.modifiers?.map((d) => d?.slug);\nconst slugs = [item?.slug, dmgSlugs, modSlugs]?.flat();\nconst animationList = slugs?.map((slug) => `damage-roll:${slug}`);\n\nconst animationName = animationList?.join(\", \");\nconst toolbeltTargets = msg?.flags?.[\"pf2e-toolbelt\"]?.targetHelper?.targets.map(uuid => canvas.tokens.placeables.find(t => t?.document?.uuid === uuid))\nlet targets = toolbeltTargets?.length > 0 ? toolbeltTargets : (msg?.target ? [msg?.target] : [])\nif (targets?.length <= 0) {\n  targets = Array.from(msg?.author?.targets ?? 0);\n}\n\nreturn [\n  { type: \"item\", value: item },\n  { type: \"text\", isArray: true, value: rollOptions },\n  { type: \"outcome\", value: outcome },\n  { type: \"boolean\", value: isReroll },\n  { type: \"text\", value: animationName },\n  { type: \"target\", value: token },\n  { type: \"target\", isArray: true, value: targets },\n  { type: \"text\", isArray: true, value: slugs}\n];"
          },
          "XBZEuuLO5U2NgWUj": {
            "connection": "GT4ukBFeZBihKFGW:outputs:targets"
