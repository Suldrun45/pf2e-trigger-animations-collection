{
  "id": "pf2e-trigger-animations-trove",
  "title": "Trigger Animation Trove (PF2e / SF2e)",
  "description": "Animations for the Trigger Animation module specifically for the Pathfinder 2e and Starfinder 2e systems",
  "version": "#{VERSION}#",
  "library": "false",
  "compatibility": {
    "minimum": 14,
    "verified": 14
  },
  "authors": [
    {
      "name": "chasarooniZ"
    }
  ],
  "relationships": {
    "systems": [
      {
        "id": "pf2e",
        "type": "system",
        "manifest": "https://github.com/foundryvtt/pf2e/releases/download/latest/system.json"
      },
      {
        "id": "sf2e",
        "type": "system",
        "manifest": "https://github.com/foundryvtt/pf2e/releases/download/latest/system.json",
        "compatibility": {
          "minimum": "0.0.3"
        }
      }
    ],
    "requires": [
      {
        "id": "trigger-animations",
        "name": "Trigger Animations",
        "type": "module",
        "manifest": "https://raw.githubusercontent.com/MrVauxs/trigger-animations/latest/releases/module.json",
        "compatibility": {
          "minimum": "0.6.1"
        }
      }
    ],
    "recommends": [
      {
        "id": "ggg",
        "name": "GGG: Sequencer Sound DB Collection",
        "type": "module",
        "reason": "For SFX for the animations",
        "compatibility": {
          "minimum": "0.0.21"
        },
        "manifest": "https://github.com/ChasarooniZ/GGG-Sequencer-Sound-DB-Collection/releases/latest/download/module.json"
      }
    ]
  },
  "esmodules": ["scripts/module.js"],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "languages/en.json"
    }
  ],
  "flags": {
    "trigger-animations": {
      "triggers": "modules/pf2e-trigger-animations-trove/animations.json"
    }
  },
  "url": "#{URL}#",
  "manifest": "#{MANIFEST}#",
  "download": "#{DOWNLOAD}#",
  "license": "LICENSE",
  "readme": "README.md"
}
