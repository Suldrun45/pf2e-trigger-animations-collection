      "inputs": {
        "script": {
          "value": "/**\n * @param {unknown[]} inputs\n * @returns {boolean} to break out current process\n * @returns {{type: EntryType; value: unknown}[]}\n *\n * @example\n * const x = inputs[0];\n * const y = inputs[1];\n * return [{type: \"number\", value: x + y}];\n */\nconst item = inputs[0];\nconst source = inputs[1];\nconst actor = source?.actor;\nlet value = item;\nif (item?.type && item?.type !== \"strike\" && actor) {\n  if (item?.linkedWeapon) {\n    value = item.linkedWeapon\n  } else {\n    const strike = actor?.system?.actions?.find(a => a?.item?.rule?.item?.slug === item?.slug);\n    if (strike?.item) {\n      value = strike?.item;\n    }\n  }\n}\n\n// Handle NPC strike\n\nif (!value?.slug) {\n  value.slug = game?.pf2e?.system?.sluggify(value.name)\n}\nif (!value?.system?.group) {\n  value.system.group = value?.group\n}\nif (!value?.system?.baseItem) {\n  value.system.baseItem = value?.baseType\n}\nconsole.log({slug: value.slug, group: value.system.group, base: value.system.baseItem})\n\n\nreturn [{type: \"item\", value: value}];"
        },
