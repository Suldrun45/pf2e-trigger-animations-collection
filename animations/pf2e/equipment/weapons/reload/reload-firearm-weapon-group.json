          "value": "/**\n * @param {unknown[]} inputs\n * @returns {boolean} to break out current process\n * @returns {{type: EntryType; value: unknown}[]}\n *\n * @example\n * const x = inputs[0];\n * const y = inputs[1];\n * return [{type: \"number\", value: x + y}];\n */\nconst traits = inputs[0];\nconst hands = inputs[1];\nlet type = 'pistol';\nif (traits.some(trait => trait?.startsWith(\"scatter\"))) {\n  type = \"shotgun\"\n} else if (hands === 2) {\n  type = \"rifle\"\n}\nreturn [{type: \"text\", value: type}];"
