          }
        },
        "outputs": {
          "oTAn9oIVZeyfblPY": {
            "id": "oTAn9oIVZeyfblPY",
            "label": "sfx",
            "slug": "output",
            "isArray": false,
            "type": "text"
          }
        }
      },
      "inputs": {
        "2vXIlxTwsJ7AwF3e": {
          "connection": "issvyytzK9Jrg9PG:outputs:entry"
        },
        "script": {
          "value": "/**\n * @param {unknown[]} inputs\n * @returns {boolean} to break out current process\n * @returns {{type: EntryType; value: unknown}[]}\n *\n * @example\n * const x = inputs[0];\n * const y = inputs[1];\n * return [{type: \"number\", value: x + y}];\n */\nconst type = inputs[0];\nlet sfx;\n\nswitch (type) {\n  case \"acid\":\n    sfx = \"ggg-sfx.ranged.bomb.acid.01\";\n    break;\n  case \"fire\":\n    sfx = \"ggg-sfx.magic.fire.impact.flame.02\";\n    break;\n  case \"light\":\n    sfx = \"ggg-sfx.ranged.bomb.light.01\";\n    break;\n  case \"sonic\":\n    sfx = \"ggg-sfx.ranged.bomb.explosion.01\";\n    break;\n  case \"poison\":\n    sfx = \"ggg-sfx.ranged.bomb.poison.01\";\n    break;\n  case \"electricity\":\n    sfx = \"ggg-sfx.ranged.bomb.electricity.01\";\n    break;\n  case \"cold\":\n    sfx = \"ggg-sfx.ranged.bomb.ice.01\";\n    break;\n  case \"earth\":\n    sfx = \"ggg-sfx.ranged.bomb.earth.01\";\n    break;\n  case \"void\":\n    sfx = \"ggg-sfx.magic.occult.impact.general.01\";\n    break;\n  case \"water\":\n    sfx = \"ggg-sfx.ranged.bomb.water.01\";\n    break;\n  case \"vitality\":\n    sfx = \"ggg-sfx.ranged.bomb.holy_water.01\";\n    break;\n  default:\n    sfx = \"ggg-sfx.ranged.bomb.break.01\";\n    break;\n}\n\nreturn [{type: \"text\", value: sfx}];"
        }
      },
      "outs": {
        "out": {
          "connection": "U0J4Ln92UEyHDqzK:ins:in"
        }
      }
    },
