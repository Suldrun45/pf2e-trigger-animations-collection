        "REkqJtygC1Y6g8sU": {
          "connection": "fIbjlk5zGRaPqV0z:outputs:9cb4N778gDJxAh1K"
        },
        "script": {
          "value": "/**\n * @param {unknown[]} inputs\n * @returns {boolean} to break out current process\n * @returns {{type: EntryType; value: unknown}[]}\n *\n * @example\n * const x = inputs[0];\n * const y = inputs[1];\n * return [{type: \"number\", value: x + y}];\n */\nconst range = inputs[0];\nconst traits = inputs[1];\nconst isAutomatic= traits.some(t=> t == \"automatic\");\nconst divider =  isAutomatic ? 10 : 5;\nlet shape = \"cone\";\nlet gridRadius = 0;\nif (!isAutomatic){\n  if (traits.some(t => t == \"area-line\")){\n    shape=\"line\";    \n  }\n  else if (traits.some(t => t.startsWith(\"area-burst-\"))){\n    shape=\"burst\";\n    const burst = traits.find(t => t.startsWith(\"area-burst-\"));\n    const regex = /(\\d+)$/gi;\n    const matches = burst.match(regex);\n    gridRadius = matches[0] * 2 / 5;\n  }  \n}\nreturn [\n  {type: \"number\", value: range * 0.25 / divider}, \n  {type: \"text\", value: shape},\n  {type: \"number\", value: gridRadius}\n];"
        },
        "PqmOJR32GPpvm4Rs": {
